[run]
branch = true
source =
    cryptography_suite
omit =
    # Template-only code is not importable runtime code.
    cryptography_suite/codegen/templates/*
    # Experimental modules are intentionally out-of-scope for v4 stability gates.
    cryptography_suite/experimental/*

[report]
show_missing = true
skip_covered = false

[html]
directory = htmlcov
